[info]
title=HTML-CSS-Markdown Tooltips
desc=In HTML/CSS/Markdown files, plugin shows tooltips for various special fragments
type=cudatext-plugin
subdir=cuda_html_tooltips
homepage=https://github.com/CudaText-addons/cuda_html_tooltips

[item1]
section=events
events=on_open,on_change_slow,on_hotspot
lexers=regex:(.*HTML.*)|PHP|CSS|SCSS|Sass|LESS|Markdown

[item2]
section=commands
caption=HTML-CSS-Markdown Tooltips\Config
method=edit_config
menu=o
